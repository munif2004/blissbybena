# Backend Environment Variables

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/blissbybena?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=production

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin email
